# ─── DynamicWorks — Environment Variables ──────────────────────────────────
# Copia este ficheiro para .env.local e preenche os valores reais
# NUNCA faças commit do .env.local ao GitHub

# ── Deriv ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ID=SEU_DERIV_APP_ID
NEXT_PUBLIC_AFFILIATE_LINK=SEU_LINK_DE_AFILIADO

# ── Firebase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=SUA_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=SEU_PROJETO.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://SEU_PROJETO-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=SEU_PROJETO_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=SEU_PROJETO.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=SEU_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=SEU_APP_ID
