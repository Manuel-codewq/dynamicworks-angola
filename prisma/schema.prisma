generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  phone        String?
  province     String?
  avatar       String?
  biNumber     String?
  balance      Float         @default(0)
  demoBalance  Float         @default(10000)
  isDemo       Boolean       @default(true)
  role         String        @default("user")
  status       String        @default("active")
  kycStatus      String        @default("pending")
  kycAttempts    Int           @default(0)
  kycBlockedUntil DateTime?
  emailVerified  Boolean       @default(false)
  verifyCode     String?
  verifyExpires  DateTime?
  otpCode        String?    // OTP de transação (depósito/levantamento)
  otpExpires     DateTime?
  pwdOtpCode     String?    // OTP de alteração de senha (separado para não conflituar)
  pwdOtpExpires  DateTime?
  indicatorPrefs Json?
  lastSeenAt     DateTime?
  createdAt      DateTime      @default(now())
  trades           Trade[]
  transactions     Transaction[]
  notifications    Notification[]
  kycSubmission    KycSubmission?
  tournaments      TournamentParticipant[]
  supportTickets   SupportTicket[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}


model Trade {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  asset      String
  direction  String
  amount     Float
  entryPrice Float
  closePrice Float?
  payout     Float     @default(0.85)
  result     String?
  profit     Float?
  expirySecs Int
  expiresAt  DateTime?
  status     String    @default("active")
  isDemo     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  closedAt   DateTime?

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  amount    Float
  method    String?
  status    String   @default("pending")
  reference String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Settings {
  id              String    @id @default("singleton")
  otcMode         String    @default("auto")
  maintenanceMode Boolean   @default(false)
  winProbability  Json      @default("{}")
  payout          Json      @default("{}")
  activePairs     Json      @default("[]")
  rankingResetAt  DateTime?
  updatedAt       DateTime  @updatedAt
}

model PriceCandle {
  id        String   @id @default(cuid())
  asset     String
  timeframe String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float    @default(0)
  timestamp DateTime
  createdAt DateTime @default(now())

  @@index([asset, timeframe, timestamp])
  @@unique([asset, timeframe, timestamp])
}

model SupportTicket {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  subject   String
  category  String           @default("outro")
  status    String           @default("open")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body      String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model RateLimit {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime

  @@index([resetAt])
}

model KycSubmission {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  faceFront String
  faceRight String
  faceLeft  String
  biFront   String
  biBack    String
  livenessScore Float @default(0)
  createdAt DateTime @default(now())
}

model Tournament {
  id              String   @id @default(cuid())
  name            String
  description     String?
  rules           String?
  startDate       DateTime
  endDate         DateTime
  prizePool       Float    @default(0)
  prizes          Json     @default("[]")
  status          String   @default("upcoming")
  isFree          Boolean  @default(true)
  entryFee        Float    @default(0)
  maxParticipants Int?
  bannerColor     String   @default("#f5a623")
  createdAt       DateTime @default(now())
  participants    TournamentParticipant[]

  @@index([status, startDate])
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  profit       Float      @default(0)
  trades       Int        @default(0)
  wins         Int        @default(0)
  joinedAt     DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId, profit])
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  adminName String
  action    String
  target    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([adminId])
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("balance")
  value       Float
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
  userId      String
  redeemedAt  DateTime  @default(now())

  @@unique([promoCodeId, userId])
  @@index([userId])
}
